{
  "Version": "v3.2.0",
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": false,
  "NoColor": false,
  "Exclude": [
    "package.json",
    "pnpm-lock.yaml",
    "sanity.types.ts",
    "ci.yaml",
    "*.hbs"
